<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <artifactId>koku</artifactId>
        <groupId>de.domschmidt</groupId>
        <version>0.0.0</version>
    </parent>

    <artifactId>koku-dashboard</artifactId>
    <version>0.0.0</version>

    <name>${project.artifactId}-${project.version}</name>

    <properties>
        <maven.compiler.release>${jdk.version}</maven.compiler.release>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    </properties>

    <dependencies>
        <dependency>
            <groupId>de.domschmidt</groupId>
            <artifactId>dashboard</artifactId>
            <version>${project.version}</version>
            <scope>compile</scope>
        </dependency>
        <dependency>
            <groupId>de.domschmidt</groupId>
            <artifactId>koku-contracts</artifactId>
            <version>${project.version}</version>
            <scope>compile</scope>
        </dependency>
        <dependency>
            <groupId>de.domschmidt</groupId>
            <artifactId>list-query</artifactId>
            <version>${project.version}</version>
            <scope>compile</scope>
        </dependency>
        <dependency>
            <groupId>org.projectlombok</groupId>
            <artifactId>lombok</artifactId>
            <version>${lombok.version}</version>
            <scope>provided</scope>
        </dependency>
        <dependency>
            <groupId>com.fasterxml.jackson.core</groupId>
            <artifactId>jackson-annotations</artifactId>
        </dependency>
        <dependency>
            <groupId>jakarta.annotation</groupId>
            <artifactId>jakarta.annotation-api</artifactId>
            <scope>provided</scope>
        </dependency>
        <dependency>
            <groupId>jakarta.validation</groupId>
            <artifactId>jakarta.validation-api</artifactId>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <plugin>
                <groupId>org.openapitools</groupId>
                <artifactId>openapi-generator-maven-plugin</artifactId>
                <version>${openapi-generator-maven-plugin.version}</version>
                <executions>
                    <execution>
                        <id>generate-koku-dashboard-dtos</id>
                        <phase>generate-sources</phase>
                        <goals>
                            <goal>generate</goal>
                        </goals>
                        <configuration>
                            <inputSpec>${project.basedir}/src/main/openapi/koku-dashboard.yml</inputSpec>
                            <generatorName>java</generatorName>
                            <output>${project.build.directory}/generated-sources/openapi/koku-dashboard</output>
                            <modelPackage>de.domschmidt.koku.dashboard.contract.dto</modelPackage>
                            <apiPackage>de.domschmidt.koku.dashboard.contract.openapi.api</apiPackage>
                            <invokerPackage>de.domschmidt.koku.dashboard.contract.openapi</invokerPackage>
                            <library>restclient</library>
                            <generateApis>false</generateApis>
                            <generateApiTests>false</generateApiTests>
                            <generateApiDocumentation>false</generateApiDocumentation>
                            <generateModelTests>false</generateModelTests>
                            <generateModelDocumentation>false</generateModelDocumentation>
                            <generateSupportingFiles>false</generateSupportingFiles>
                            <schemaMappings>
                                <schemaMapping>DashboardView=de.domschmidt.dashboard.contract.dto.DashboardView</schemaMapping>
                                <schemaMapping>DashboardContent=de.domschmidt.dashboard.contract.dto.DashboardContent</schemaMapping>
                                <schemaMapping>DashboardContainer=de.domschmidt.dashboard.contract.dto.DashboardContainer</schemaMapping>
                                <schemaMapping>DashboardPanel=de.domschmidt.dashboard.contract.dto.DashboardPanel</schemaMapping>
                                <schemaMapping>KokuColor=de.domschmidt.koku.contracts.dto.KokuColor</schemaMapping>
                            </schemaMappings>
                            <importMappings>
                                <importMapping>DashboardView=de.domschmidt.dashboard.contract.dto.DashboardView</importMapping>
                                <importMapping>DashboardContent=de.domschmidt.dashboard.contract.dto.DashboardContent</importMapping>
                                <importMapping>DashboardContainer=de.domschmidt.dashboard.contract.dto.DashboardContainer</importMapping>
                                <importMapping>DashboardPanel=de.domschmidt.dashboard.contract.dto.DashboardPanel</importMapping>
                                <importMapping>KokuColor=de.domschmidt.koku.contracts.dto.KokuColor</importMapping>
                            </importMappings>
                            <configOptions>
                                <openApiNullable>false</openApiNullable>
                                <serializationLibrary>jackson</serializationLibrary>
                                <dateLibrary>java8-localdatetime</dateLibrary>
                                <sourceFolder>src/gen/java</sourceFolder>
                                <useOneOfInterfaces>true</useOneOfInterfaces>
                                <useBeanValidation>true</useBeanValidation>
                                <useJakartaEe>true</useJakartaEe>
                            </configOptions>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <version>${maven-compiler-plugin.version}</version>
                <configuration>
                    <source>${jdk.version}</source>
                    <target>${jdk.version}</target>
                    <release>${jdk.version}</release>
                    <encoding>${project.build.sourceEncoding}</encoding>
                    <annotationProcessorPaths>
                        <path>
                            <groupId>org.projectlombok</groupId>
                            <artifactId>lombok</artifactId>
                            <version>${lombok.version}</version>
                        </path>
                    </annotationProcessorPaths>
                </configuration>
            </plugin>
        </plugins>
    </build>
</project>
